pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                url: 'https://github.com/veeraprasadkoduri-cmd/java-project-maven.git'
            }
        }

        stage('Build') {
            steps {
                sh '''
                pwd
                ls -l
                mvn clean install
                '''
            }
        }

    }
}
